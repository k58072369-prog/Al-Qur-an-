# Copy this file to ".env" and fill in the values, OR set the variable
# directly in Replit's Secrets panel (recommended).
#
# Required for the MOTQN.ai chat (Google Gemini API).
# Note: Expo bundles only variables that start with EXPO_PUBLIC_ into the
# client app, so the key MUST keep this exact name.
EXPO_PUBLIC_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
